import java.util.HashMap;
import java.util.Map;
import java.util.Scanner;

public class Main {

    public static void main(String[] args) {
        // Sample hardcoded exchange rates relative to USD
        Map<String, Double> exchangeRates = new HashMap<>();
        exchangeRates.put("USD", 1.0);
        exchangeRates.put("INR", 83.5);
        exchangeRates.put("EUR", 0.91);
        exchangeRates.put("GBP", 0.78);
        exchangeRates.put("JPY", 157.3);
        exchangeRates.put("AUD", 1.48);

        Scanner scanner = new Scanner(System.in);

        // Input
        System.out.print("Enter base currency (e.g. USD): ");
        String base = scanner.next().toUpperCase();

        System.out.print("Enter target currency (e.g. INR): ");
        String target = scanner.next().toUpperCase();

        System.out.print("Enter amount to convert: ");
        double amount = scanner.nextDouble();

        // Validate
        if (!exchangeRates.containsKey(base) || !exchangeRates.containsKey(target)) {
            System.out.println("Unsupported currency. Supported: USD, INR, EUR, GBP, JPY, AUD");
        } else {
            // Convert amount
            double usdAmount = amount / exchangeRates.get(base); // convert to USD
            double convertedAmount = usdAmount * exchangeRates.get(target); // convert to target

            // Display result
            System.out.printf("%.2f %s = %.2f %s\n", amount, base, convertedAmount, target);
        }

        scanner.close();
    }
}
